{
  "name": "@janguenzel/trello",
  "version": "0.1.0",
  "description": "TypeScript wrapper for the Trello REST API — all endpoints typed, rate-limit aware",
  "type": "module",
  "author": "Jan Henning Günzel <npm@jan-guenzel.de>",
  "license": "MIT",
  "homepage": "https://github.com/janguenzel/trello#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/janguenzel/trello.git"
  },
  "bugs": {
    "url": "https://github.com/janguenzel/trello/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "trello",
    "trello-rest-api-wrapper",
    "api",
    "typescript",
    "rest-api",
    "atlassian",
    "type-safe",
    "queue",
    "rate-limiting"
  ],
  "scripts": {
    "update-spec": "tsx codegen/src/update-spec.ts",
    "codegen": "tsx codegen/src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/unit/*.test.ts tests/codegen/*.test.ts tests/integration/*.test.ts",
    "test:coverage": "tsx --test --experimental-test-coverage tests/unit/*.test.ts tests/codegen/*.test.ts tests/integration/*.test.ts",
    "test:unit": "tsx --test tests/unit/*.test.ts",
    "test:codegen": "tsx --test tests/codegen/*.test.ts",
    "test:integration": "tsx --test tests/integration/*.test.ts",
    "build": "tsc -p tsconfig.build.json",
    "check:spec": "tsx codegen/src/check-spec.ts",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build",
    "release": "changeset publish",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^25.9.1",
    "msw": "^2.0.0",
    "tsd": "^0.31.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
